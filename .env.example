# VulcanPaaS Environment Variables
# Copy this file to .env and fill in values
# cp .env.example .env  (Linux/Mac)
# Copy-Item .env.example .env  (Windows)

# API
NODE_ENV=production
API_PORT=8080

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# Image tag (used by deploy pipeline)
IMAGE_TAG=latest

# GitHub Container Registry
GHCR_IMAGE=ghcr.io/sejall0112/vulcanpaas